# Since the ".env" file is gitignored, you can use the ".env.example" file to
# build a new ".env" file when you clone the repo. Keep this file up-to-date
# when you add new variables to `.env`.

# This file will be committed to version control, so make sure not to have any
# secrets in it. If you are cloning this repo, create a copy of this file named
# ".env" and populate it with your secrets.

# When adding additional environment variables, the schema in "/src/env.js"
# should be updated accordingly.

# URL of the Baitin bot HTTP API (Elysia server)
BOT_API_URL="http://localhost:3000"

# Discord OAuth invite URL for the "Add to Discord" button
NEXT_PUBLIC_DISCORD_INVITE_URL="https://discord.com/oauth2/authorize?client_id=YOUR_CLIENT_ID&permissions=0&scope=bot"

# PostgreSQL — same database as the bot
DATABASE_URL="postgresql://baitin:password@localhost:5435/baitin"

# Discord OAuth app (create at discord.com/developers)
DISCORD_CLIENT_ID="your_client_id"
DISCORD_CLIENT_SECRET="your_client_secret"

# Auth secrets — generate with: openssl rand -base64 32
BETTER_AUTH_SECRET="generate_a_random_32_char_secret"

# Shared secret between web and bot for signed API tokens
BOT_API_SECRET="generate_a_random_32_char_secret"
